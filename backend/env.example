# ─── AgentSpark Backend — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── CORS ────────────────────────────────────────────────────────────────────
# Production: set to your exact frontend origin, e.g. https://yourdomain.com
CORS_ORIGIN=http://localhost:5173

# ─── Auth ────────────────────────────────────────────────────────────────────
# Must be a long, random secret. Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_with_crypto_randomBytes_64

# ─── HMAC Request Signing ────────────────────────────────────────────────────
# Required in production (server exits on startup if missing).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
REQUEST_HMAC_SECRET=CHANGE_ME_generate_with_crypto_randomBytes_32

# ─── Firebase ────────────────────────────────────────────────────────────────
# Service account JSON — either inline or as a file path
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}
# FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/serviceAccount.json

# ─── API Keys (used when KEY_MODE=env or KEY_MODE=hybrid) ────────────────────
KEY_MODE=hybrid

GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=

# ─── RevenueCat (optional, for server-side Pro entitlement checks) ────────────
# Server-side secret key (NOT the public API key used in the frontend SDK)
# Get from: RevenueCat Dashboard → Project → API Keys → Secret keys
REVENUECAT_SECRET_KEY=

# ─── Rate Limiting ────────────────────────────────────────────────────────────
GLOBAL_RATE_LIMIT_WINDOW_MS=60000
GLOBAL_RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
GENERATE_RATE_LIMIT_WINDOW_MS=60000
GENERATE_RATE_LIMIT_MAX=10

# ─── Optional: Sentry DSN for error tracking ─────────────────────────────────
# SENTRY_DSN=https://example@sentry.io/123
