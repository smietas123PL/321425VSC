# ─── SERVER ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# CORS: comma-separated list of allowed frontend origins
# REQUIRED in production (server exits if not set)
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# ─── FIREBASE / FIRESTORE ─────────────────────────────────
# REQUIRED: Firebase Admin SDK service account JSON (stringified)
# How to get it:
#   1. Firebase Console → Project Settings → Service Accounts
#   2. Generate new private key → download JSON
#   3. Stringify: JSON.stringify(require('./serviceAccount.json'))
#   4. Paste the single-line JSON string here
# In production (Render/Railway): set as env variable, never commit this file
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# Fallback: if FIREBASE_SERVICE_ACCOUNT is not set, SDK uses GOOGLE_APPLICATION_CREDENTIALS
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccount.json

# ─── JWT SECRET ───────────────────────────────────────────
# REQUIRED: minimum 32 chars, random string
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=REPLACE_ME_with_a_long_random_string_at_least_32_chars

# REQUIRED for HMAC request verification on /api/v1/generate
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
REQUEST_HMAC_SECRET=REPLACE_ME_with_another_random_string

# Key mode for LLM proxy:
#   env    - always use server-side keys (ignore client key)
#   byok   - always require clientApiKey from frontend
#   hybrid - prefer server key, fall back to client key (recommended)
KEY_MODE=hybrid

# ─── LLM API KEYS ─────────────────────────────────────────
# Only needed if KEY_MODE=env or KEY_MODE=hybrid
# NEVER commit actual keys — set them as env vars in your deployment platform
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...
MISTRAL_API_KEY=...
GEMINI_API_KEY=AIza...

# ─── GOOGLE OAUTH ─────────────────────────────────────────
# Required for Google Sign-In flow (/api/v1/auth/callback)
# Get from: console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
# Must match the redirect URI registered in Google Console
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/callback

# ─── RATE LIMITING ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── LOGGING ──────────────────────────────────────────────
LOG_LEVEL=info
