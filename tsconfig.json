{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "lib": [
            "ES2020",
            "DOM"
        ],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "moduleResolution": "node",
        "allowJs": true,
        "checkJs": false,
        "noEmit": true
    },
    "include": [
        "js/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}