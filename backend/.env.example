# ─── SERVER ───────────────────────────────────
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000,https://agentspark.app

# ─── DATABASE ──────────────────────────────────
DATABASE_PATH=./data/agentspark.db

# ─── JWT SECRET ────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production
REQUEST_HMAC_SECRET=change_me_hmac_secret
KEY_MODE=hybrid

# ─── LLM API KEYS (SENSITIVE) ──────────────────
# NOTE: These should NEVER be exposed to frontend
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...
MISTRAL_API_KEY=...
GEMINI_API_KEY=AIza...

# ─── GOOGLE OAUTH (FUTURE) ─────────────────────
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/callback

# ─── RATE LIMITING ─────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── LOGGING ───────────────────────────────────
LOG_LEVEL=info
